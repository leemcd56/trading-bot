# Alpaca (paper trading)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
# Paper trading (v2 API). Use exactly what Alpaca shows in your dashboard (with or without /v2).
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Data providers
# Massive (primary, recommended). Get a key at https://massive.com
MASSIVE_API_KEY=your_massive_api_key_here

# Finnhub (optional fallback)
FINNHUB_API_KEY=your_finnhub_token_here

# FMP (Financial Modeling Prep) — analyst upgrades/downgrades signal feed.
# When set, the bot queries today's analyst actions each hour and buys/sells
# accordingly, bypassing TA gates (but still respecting all risk limits).
# Free tier: 250 calls/day, well within the hourly polling budget.
# Get a key at https://financialmodelingprep.com/developer/docs
# FMP_API_KEY=your_fmp_api_key_here

# Optional: MotherDuck (hosted DuckDB) for persistent cloud storage. If set, trends and trade_log
# are stored in MotherDuck instead of a local trends.db file. Get a token at https://motherduck.com
# MOTHERDUCK_TOKEN=your_motherduck_token_here

# Symbols to watch. Comma-separated list; defaults to AAPL,TSLA,GOOG,MSFT if not set.
# WATCH_SYMBOLS=AAPL,TSLA,GOOG,MSFT

# Optional: LOG_LEVEL=INFO

# Alerts: Discord webhook (recommended). Create in Server Settings → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: email on errors only
# ALERT_EMAIL_SMTP_URL=smtps://user:pass@smtp.example.com:465
# ALERT_EMAIL_FROM=bot@example.com
# ALERT_EMAIL_TO=you@example.com
